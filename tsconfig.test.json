{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": ".test-dist",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": [
    "lib/notification-payloads.ts",
    "lib/routing/**/*.ts",
    "lib/supabase/route-access.ts",
    "tests/**/*.ts",
    "types/index.ts",
    "lib/supabase/env.ts"
  ]
}
